# Auction Bid Dashboard environment
#
# Copy this file to `.env` and fill in the real values.

# Required for YouTube live chat polling
YOUTUBE_API_KEY=your_youtube_api_key_here

# Required for Facebook and Instagram comment polling
META_ACCESS_TOKEN=your_meta_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Optional server port (defaults to 3069)
AUCTION_PORT=3069
