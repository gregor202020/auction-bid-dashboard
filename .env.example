# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://twb_app:PASSWORD@127.0.0.1:5432/twb_analytics

# ── Meta (Facebook & Instagram) API Keys ──────────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token_here
APP_ID=your_app_id_here
APP_SECRET=your_app_secret_here
INSTAGRAM_USER_ID=your_instagram_user_id_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
META_API_VERSION=v21.0

# ── YouTube API Keys ───────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# ── Threads API Keys ──────────────────────────────────────────────────────────────────────
THREADS_USER_ID=your_threads_user_id_here
THREADS_ACCESS_TOKEN=                          # Optional: falls back to META_ACCESS_TOKEN

# ── TikTok API Keys ────────────────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# ── Twitter / X API Keys ───────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ── Anthropic API Key ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Agent Scheduling ───────────────────────────────────────────────────────────
AGENT_CRON_SCHEDULE=0 9 * * *
AGENT_TIMEZONE=Australia/Melbourne

# ── Google Places / Vision API ────────────────────────────────────────────────
GOOGLE_VISION_API_KEY=your_google_api_key_here

# ── Google Business Profile API (for pulling ALL Google reviews) ─────────────
GOOGLE_GMB_CLIENT_ID=your_gmb_oauth_client_id
GOOGLE_GMB_CLIENT_SECRET=your_gmb_oauth_client_secret
GOOGLE_GMB_REFRESH_TOKEN=your_gmb_refresh_token
GOOGLE_GMB_ACCOUNT_ID=accounts/your_account_id

# ── Reviews API Key (optional — leave blank for open access) ─────────────────
REVIEWS_API_KEY=

# ── Gift Voucher System ──────────────────────────────────────────────────────
VOUCHER_API_URL=https://gift-vouchers.thirdwavebbq.com.au/api
VOUCHER_API_EMAIL=your_voucher_admin_email
VOUCHER_API_PASSWORD=your_voucher_admin_password

# ── Email Sending (AWS SES) ──────────────────────────────────────────────────
AWS_SES_REGION=ap-southeast-2
AWS_SES_ACCESS_KEY=your_aws_access_key
AWS_SES_SECRET_KEY=your_aws_secret_key
SENDER_EMAIL=info@thirdwavebbq.com.au
SENDER_NAME=Third Wave BBQ

# ── Google OAuth (Dashboard Auth) ─────────────────────────────────────────────
SESSION_SECRET=generate-a-random-64-char-hex-string
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=https://analytics.thirdwavebbq.com.au/auth/google/callback
GOOGLE_WHITELIST=gregrips@gmail.com

# ── Slack Alerts ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=C097FLTGXS6

# ── Google Sheets Web App ─────────────────────────────────────────────────────
GOOGLE_SHEETS_WEBAPP_URL=your_google_sheets_webapp_url_here
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
