# Auction Bid Dashboard environment
#
# Copy this file to `.env` and fill in the real values.

# Required for YouTube live chat polling
# Prefer a dedicated key for this standalone app so quota is not shared.
AUCTION_YOUTUBE_API_KEY=your_dedicated_auction_youtube_api_key_here
# Optional quota failover keys (comma-separated). First key can be the same as AUCTION_YOUTUBE_API_KEY.
# AUCTION_YOUTUBE_API_KEYS=key_1,key_2,key_3
# Backward-compatible fallback if you have not split keys yet:
# YOUTUBE_API_KEY=your_youtube_api_key_here

# Required for Facebook and Instagram comment polling
META_ACCESS_TOKEN=your_meta_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Optional server port (defaults to 3069)
AUCTION_PORT=3069
